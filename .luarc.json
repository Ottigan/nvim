{
  "runtime": {
    "version": "LuaJIT",
    "path": ["lua/?.lua", "lua/?/init.lua"]
  },
  "diagnostics": {
    "globals": ["vim"]
  },
  "workspace": {
    "library": [
      "${3rd}/luv/library",
      "/opt/homebrew/share/nvim/runtime/lua"
    ],
    "checkThirdParty": false
  },
  "telemetry": {
    "enable": false
  }
}
